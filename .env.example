# ═══════════════════════════════════════════════════════════════════
# SUPABASE (Obligatoire - Base de données + Auth)
# ═══════════════════════════════════════════════════════════════════
# 1. Allez sur https://app.supabase.com → New Project
# 2. Copiez Project URL et anon key depuis Settings → API
# 3. Copiez service_role key (privilégié, server-side uniquement)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ═══════════════════════════════════════════════════════════════════
# IA AWA (Google AI Studio - Gemini)
# ═══════════════════════════════════════════════════════════════════
GEMINI_API_KEY=votre_cle_gemini_ici

# ═══════════════════════════════════════════════════════════════════
# APPLICATION
# ═══════════════════════════════════════════════════════════════════
NEXT_PUBLIC_APP_URL=http://localhost:9002

# ═══════════════════════════════════════════════════════════════════
# SUPERADMIN (Optionnel - Email du superadmin pour l'auto-création)
# ═══════════════════════════════════════════════════════════════════
# Si défini, un utilisateur s'inscrivant avec cet email obtiendra
# automatiquement le rôle 'superadmin'. À utiliser UNIQUEMENT pour
# le premier déploiement. Protégez cet email comme un mot de passe.
SUPERADMIN_EMAIL=
