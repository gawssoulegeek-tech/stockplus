# ============================================================
# StockPlus — Variables d'environnement
# ============================================================
# Copiez ce fichier en .env.local (développement) ou configurez
# les variables directement sur Vercel (production).
# ============================================================

# ---- Supabase ----
# URL du projet Supabase (ex: https://xxxxx.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Clé ANON (publique, côté client) — exposée au navigateur
SUPABASE_ANON_KEY=your-anon-key

# ⚠️ Clé SERVICE ROLE (secrète, serveur uniquement) — JAMAIS côté client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Email (Resend) ----
# Clé API Resend pour l'envoi d'emails (rapports, notifications)
RESEND_API_KEY=re_xxxxxxxxxxxx

# ---- IA (Google Gemini) ----
# Clé API Gemini pour les fonctionnalités IA (insights, scan, etc.)
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ---- Superadmin (bootstrap) ----
# Email du premier utilisateur qui aura les droits superadmin SaaS
SUPERADMIN_EMAIL=admin@stockplus.app

# ---- Cron jobs (sécurité) ----
# Secret partagé pour authentifier les appels au cron (/api/cron/*)
CRON_SECRET=your-random-long-secret-string

# ---- Application ----
# URL publique de l'app (sans slash final)
NEXT_PUBLIC_APP_URL=https://your-domain.com
